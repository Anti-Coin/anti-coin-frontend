# frontend (Vite: only VITE_* is exposed to browser)
# Backend-blind contract: FE consumes static JSON + /status only.

# Static files origin (manifest/history/prediction).
# Example: http://<backend-ip>
VITE_STATIC_BASE_URL=http://127.0.0.1

# Status API origin.
# Example: http://<backend-ip>:8000
VITE_STATUS_BASE_URL=http://127.0.0.1:8000

# Contract paths/files.
VITE_STATIC_BASE_PATH=/static
VITE_MANIFEST_FILE=manifest.json

# Polling baseline (seconds)
# - manifest: global snapshot refresh
# - status: selected symbol/timeframe health refresh
# - background_manifest: slower refresh when tab is hidden
VITE_MANIFEST_POLL_SECONDS=120
VITE_STATUS_POLL_SECONDS=60
VITE_BACKGROUND_MANIFEST_POLL_SECONDS=600

# Retry/backoff baseline (milliseconds)
VITE_BACKOFF_STEPS_MS=5000,15000,30000,60000

# UI defaults
VITE_PRIMARY_TIMEFRAME=1h
